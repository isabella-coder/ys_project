.hero {
  background: #111111;
  color: #f8fafc;
  border: 2rpx solid #111111;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-subtitle {
  margin-top: 8rpx;
  color: #d1d5db;
}

.account-card {
  border: 2rpx solid #d1d5db;
  background: #ffffff;
}

.account-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
}

.account-subtitle {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.account-picker {
  margin-top: 16rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 16rpx 18rpx;
  color: #111827;
  background: #f9fafb;
}

.logout-btn {
  margin-top: 16rpx;
}

.sync-card .section-title {
  margin-bottom: 12rpx;
}

.sync-status {
  display: inline-block;
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.sync-ok {
  background: #e6f9ee;
  color: #106a3d;
}

.sync-warning {
  background: #fff7e8;
  color: #9a6700;
}

.sync-error {
  background: #ffecec;
  color: #b42318;
}

.sync-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.sync-btn {
  margin-top: 0;
  width: auto;
  flex: 1;
}

.entry-card {
  border: 2rpx solid #d1d5db;
  box-shadow: 0 8rpx 18rpx rgba(17, 17, 17, 0.05);
  transition: all 0.2s ease;
}

.entry-card-disabled {
  opacity: 0.6;
}

.film-entry {
  background: #ffffff;
  color: #111111;
  border-left: 8rpx solid #111111;
}

.wash-entry {
  background: #fafafa;
  color: #111111;
  border-left: 8rpx solid #6b7280;
}

.entry-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10rpx;
}

.entry-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #111111;
}

.entry-type {
  font-size: 20rpx;
  color: #6b7280;
  background: #f3f4f6;
  border: 2rpx solid #e5e7eb;
  border-radius: 999rpx;
  padding: 2rpx 14rpx;
}

.entry-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #4b5563;
}

.entry-action {
  margin-top: 18rpx;
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 22rpx;
  letter-spacing: 0.5rpx;
}

.entry-arrow {
  margin-left: 6rpx;
  opacity: 0.8;
}

.quick-card .section-title {
  margin-bottom: 16rpx;
  color: #111111;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.quick-item {
  border: 2rpx solid #d1d5db;
  background: #ffffff;
  border-radius: 14rpx;
  padding: 20rpx;
  text-align: center;
  color: #111827;
  font-weight: 500;
  box-shadow: inset 0 0 0 1rpx #f3f4f6;
}

.quick-item-disabled {
  opacity: 0.55;
}
