.dashboard {
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* ─── Header ─── */
.dash-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 28rpx;
  background: #ffffff;
  border: none;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  color: #1a1d21;
  margin-bottom: 28rpx;
}

.greeting {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1d21;
  letter-spacing: 0.5rpx;
}

.store-tag {
  display: inline-block;
  margin-top: 10rpx;
  font-size: 22rpx;
  background: #f0f1f3;
  color: #6b7280;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  width: fit-content;
  font-weight: 500;
}

.date-text {
  font-size: 24rpx;
  color: #6b7280;
}

/* ─── Stats Grid ─── */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.stat-card {
  background: #ffffff;
  border: none;
  padding: 28rpx 20rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  border-radius: 16rpx 0 0 16rpx;
}

.stat-total::before { background: #1a1d21; }
.stat-pending::before { background: #f59e0b; }
.stat-reply::before { background: #10b981; }
.stat-wechat::before { background: #3b82f6; }

.stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
}

.stat-total .stat-value { color: #1a1d21; }
.stat-pending .stat-value { color: #f59e0b; }
.stat-reply .stat-value { color: #10b981; }
.stat-wechat .stat-value { color: #3b82f6; }

/* ─── Operations Entry ─── */
.ops-entry {
  background: #ffffff;
  border: none;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  color: #1a1d21;
  padding: 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ops-entry-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.ops-role-tag {
  font-size: 20rpx;
  border: none;
  background: #f0f1f3;
  color: #6b7280;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.ops-entry-main {
  display: flex;
  flex-direction: column;
}

.ops-entry-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
  color: #1a1d21;
}

.ops-entry-subtitle {
  font-size: 24rpx;
  color: #6b7280;
}

.ops-entry-arrow {
  font-size: 26rpx;
  color: #3b82f6;
  font-weight: 500;
}

.legacy-entry {
  margin-top: 0;
}

/* ─── Sections ─── */
.section {
  background: #ffffff;
  border: none;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1d21;
}

.section-more {
  font-size: 24rpx;
  color: #3b82f6;
  font-weight: 500;
}

/* ─── Loading & Empty States ─── */
.loading-box {
  padding: 40rpx 0;
}

.empty-box {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #6b7280;
}

.empty-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: #f0f1f3;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-check {
  width: 36rpx;
  height: 20rpx;
  border-left: 4rpx solid #c4cad4;
  border-bottom: 4rpx solid #c4cad4;
  transform: rotate(-45deg);
  margin-top: -6rpx;
}

.skeleton-lead {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f1f3;
}

/* ─── Lead List ─── */
.lead-item {
  padding: 24rpx 0;
  padding-left: 20rpx;
  border-bottom: 1rpx solid #f0f1f3;
  position: relative;
}

.lead-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 3rpx;
  background: #e8eaed;
}

.lead-item.status-assigned::before { background: #f59e0b; }
.lead-item.status-first_reply::before { background: #3b82f6; }
.lead-item.status-wechat_invited::before { background: #8b5cf6; }

.lead-item:last-child {
  border-bottom: none;
}

.lead-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.lead-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1d21;
}

.lead-platform {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.tag-dy {
  background: #1a1d21;
  color: #ffffff;
}

.tag-xhs {
  background: #ff2442;
  color: #ffffff;
}

.lead-info {
  display: flex;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.lead-car, .lead-service {
  font-size: 24rpx;
  color: #6b7280;
}

.lead-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.lead-time {
  font-size: 22rpx;
  color: #c4cad4;
}

.lead-status {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.status-assigned {
  background: #fef3c7;
  color: #92400e;
}

.status-first_reply {
  background: #d1fae5;
  color: #065f46;
}
