.dashboard {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 头部 */
.dash-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  border-radius: 16rpx;
  color: #fff;
  margin-bottom: 24rpx;
}

.greeting {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 36rpx;
  font-weight: bold;
}

.store-tag {
  display: inline-block;
  margin-top: 8rpx;
  font-size: 22rpx;
  background: rgba(255,255,255,0.25);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  width: fit-content;
}

.date-text {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 统计卡片 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.stat-total .stat-value { color: #409eff; }
.stat-pending .stat-value { color: #e6a23c; }
.stat-reply .stat-value { color: #67c23a; }
.stat-wechat .stat-value { color: #f56c6c; }

/* 经营中心入口 */
.ops-entry {
  background: linear-gradient(135deg, #1f2a44, #2f4f80);
  border-radius: 12rpx;
  color: #fff;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ops-entry-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.ops-role-tag {
  font-size: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.ops-entry-main {
  display: flex;
  flex-direction: column;
}

.ops-entry-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.ops-entry-subtitle {
  font-size: 22rpx;
  opacity: 0.88;
}

.ops-entry-arrow {
  font-size: 24rpx;
  opacity: 0.95;
}

.legacy-entry {
  background: linear-gradient(135deg, #2c3250, #4a5f9a);
  margin-top: -6rpx;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #409eff;
}

/* 加载和空态 */
.loading-box, .empty-box {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
}

.empty-icon {
  display: block;
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
}

/* 线索列表 */
.lead-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.lead-item:last-child {
  border-bottom: none;
}

.lead-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.lead-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.lead-platform {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.tag-dy {
  background: #111;
  color: #fff;
}

.tag-xhs {
  background: #fe2c55;
  color: #fff;
}

.lead-info {
  display: flex;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.lead-car, .lead-service {
  font-size: 24rpx;
  color: #666;
}

.lead-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.lead-time {
  font-size: 22rpx;
  color: #bbb;
}

.lead-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.status-assigned {
  background: #fdf6ec;
  color: #e6a23c;
}

.status-first_reply {
  background: #f0f9eb;
  color: #67c23a;
}
