.profile-page {
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* ─── Profile Card ─── */
.profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #ffffff;
  border: none;
  padding: 40rpx 32rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.avatar-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1a1d21, #374151);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 700;
}

.profile-info {
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1d21;
}

.profile-store {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 6rpx;
}

/* ─── Sections ─── */
.section {
  background: #ffffff;
  border: none;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1d21;
  margin-bottom: 20rpx;
}

/* ─── My Stats ─── */
.my-stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.my-stat {
  text-align: center;
  padding: 24rpx;
  background: #f8f9fb;
  border: none;
  border-radius: 14rpx;
  position: relative;
  overflow: hidden;
}

.my-stat::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
}

.my-stat:nth-child(1)::before { background: #1a1d21; }
.my-stat:nth-child(2)::before { background: #10b981; }
.my-stat:nth-child(3)::before { background: #3b82f6; }
.my-stat:nth-child(4)::before { background: #f59e0b; }

.my-stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1d21;
  letter-spacing: -1rpx;
}

.my-stat-label {
  display: block;
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 6rpx;
  font-weight: 500;
}

/* ─── Store Stats ─── */
.store-stats {
  display: flex;
  flex-direction: column;
}

.store-stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f1f3;
}

.store-stat-row:last-child {
  border-bottom: none;
}

.store-stat-label {
  font-size: 26rpx;
  color: #6b7280;
}

.store-stat-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1d21;
}

/* ─── Daily Report ─── */
.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.report-date {
  font-size: 24rpx;
  color: #6b7280;
  background: #f0f1f3;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.report-summary {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.report-empty {
  text-align: center;
  color: #c4cad4;
  font-size: 24rpx;
  padding: 24rpx 0;
}

.report-error-box {
  background: #fef2f2;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.report-error-text {
  display: block;
  color: #dc2626;
  font-size: 24rpx;
}

.report-retry-btn {
  margin-top: 12rpx;
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  background: #1a1d21;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 500;
}

.report-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.report-row {
  padding: 18rpx;
  background: #f8f9fb;
  border: none;
  border-radius: 12rpx;
}

.report-name {
  font-size: 26rpx;
  color: #1a1d21;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.report-metrics {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #6b7280;
}

/* ─── SLA Rules ─── */
.sla-rules {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sla-rule {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 18rpx;
  background: #f8f9fb;
  border: none;
  border-radius: 12rpx;
}

.sla-time {
  font-size: 24rpx;
  font-weight: 600;
  color: #1a1d21;
  white-space: nowrap;
}

.sla-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* ─── Logout ─── */
.logout-btn {
  text-align: center;
  padding: 28rpx;
  color: #dc2626;
  font-size: 28rpx;
  margin-top: 20rpx;
  font-weight: 500;
}
