.leads-page {
  padding-bottom: 120rpx;
}

/* Tab 栏 */
.tab-bar {
  white-space: nowrap;
  background: #fff;
  padding: 16rpx 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}

.tab-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 30rpx;
  background: #f5f5f5;
}

.tab-active {
  background: #409eff;
  color: #fff;
}

/* 时间筛选栏 */
.date-filter-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 20rpx;
  background: #fff;
  border-top: 1rpx solid #f2f2f2;
}

.date-picker {
  min-width: 150rpx;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #f7f8fa;
  color: #333;
  font-size: 24rpx;
  text-align: center;
}

.date-sep {
  color: #999;
  font-size: 22rpx;
}

.filter-btn {
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.btn-apply {
  background: #409eff;
  color: #fff;
}

.btn-reset {
  background: #f2f3f5;
  color: #666;
}

/* 线索列表 */
.lead-list {
  padding: 16rpx 20rpx;
}

/* 加载和空态 */
.loading-box, .empty-box {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
}

/* 线索卡片 */
.lead-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.customer-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.platform-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.tag-dy {
  background: #111;
  color: #fff;
}

.tag-xhs {
  background: #fe2c55;
  color: #fff;
}

/* 状态标签 */
.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.status-assigned {
  background: #fdf6ec;
  color: #e6a23c;
}

.status-first_reply {
  background: #f0f9eb;
  color: #67c23a;
}

.status-wechat_invited {
  background: #ecf5ff;
  color: #409eff;
}

.status-completed {
  background: #f5f5f5;
  color: #999;
}

/* 卡片内容 */
.card-body {
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 8rpx;
}

.info-item {
  font-size: 24rpx;
  color: #666;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
}

.time-text {
  font-size: 22rpx;
  color: #bbb;
}

.quick-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-weight: 500;
}

.action-reply {
  background: #409eff;
  color: #fff;
}

/* 加载更多 */
.loading-more, .no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #ccc;
}
