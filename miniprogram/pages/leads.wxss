.leads-page {
  padding-bottom: 140rpx;
}

/* ─── Tab Bar ─── */
.tab-bar {
  white-space: nowrap;
  background: #ffffff;
  border: none;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  padding: 16rpx 20rpx;
  margin: 20rpx 24rpx 0;
}

.tab-item {
  display: inline-block;
  padding: 14rpx 28rpx;
  margin-right: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
  border-radius: 12rpx;
  background: transparent;
  font-weight: 500;
  transition: all 0.25s ease;
  position: relative;
}

.tab-active {
  background: #1a1d21;
  color: #ffffff;
  transform: scale(1.02);
}

/* ─── Date Filter ─── */
.date-filter-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #ffffff;
  border: none;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin: 12rpx 24rpx 0;
}

.date-picker {
  min-width: 160rpx;
  padding: 10rpx 16rpx;
  border-radius: 10rpx;
  background: #f8f9fb;
  color: #1a1d21;
  font-size: 24rpx;
  text-align: center;
  border: 2rpx solid #e8eaed;
}

.date-sep {
  color: #c4cad4;
  font-size: 22rpx;
}

.filter-btn {
  padding: 10rpx 18rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.btn-apply {
  background: #1a1d21;
  color: #ffffff;
}

.btn-reset {
  background: #f0f1f3;
  color: #6b7280;
}

/* ─── Lead List ─── */
.lead-list {
  padding: 16rpx 24rpx;
}

/* ─── Loading & Empty ─── */
.loading-box {
  padding: 40rpx 0;
}

.empty-box {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: #f0f1f3;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-mailbox {
  width: 48rpx;
  height: 40rpx;
  border: 4rpx solid #c4cad4;
  border-radius: 6rpx;
  position: relative;
}

.empty-mailbox::after {
  content: '';
  position: absolute;
  top: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  border-left: 22rpx solid transparent;
  border-right: 22rpx solid transparent;
  border-top: 16rpx solid #c4cad4;
}

.empty-text {
  font-size: 28rpx;
  color: #6b7280;
}

/* ─── Lead Card ─── */
.lead-card {
  background: #ffffff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx;
  padding-left: 30rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
}

.lead-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
}

.lead-card.status-assigned::before { background: #f59e0b; }
.lead-card.status-first_reply::before { background: #10b981; }
.lead-card.status-wechat_invited::before { background: #3b82f6; }
.lead-card.status-completed::before { background: #e8eaed; }

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.customer-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1d21;
}

.platform-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.tag-dy {
  background: #1a1d21;
  color: #ffffff;
}

.tag-xhs {
  background: #ff2442;
  color: #ffffff;
}

/* ─── Status Tags ─── */
.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.status-assigned {
  background: #fef3c7;
  color: #92400e;
}

.status-first_reply {
  background: #d1fae5;
  color: #065f46;
}

.status-wechat_invited {
  background: #dbeafe;
  color: #1e40af;
}

.status-completed {
  background: #f0f1f3;
  color: #6b7280;
}

/* ─── Card Body ─── */
.card-body {
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f1f3;
}

.info-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 8rpx;
}

.info-item {
  font-size: 24rpx;
  color: #6b7280;
}

/* ─── Card Footer ─── */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
}

.time-text {
  font-size: 22rpx;
  color: #c4cad4;
}

.quick-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 12rpx 28rpx;
  border-radius: 10rpx;
  font-weight: 500;
  min-width: 88rpx;
  text-align: center;
}

.action-reply {
  background: #1a1d21;
  color: #ffffff;
}

/* ─── Load More ─── */
.loading-more, .no-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: #c4cad4;
}
