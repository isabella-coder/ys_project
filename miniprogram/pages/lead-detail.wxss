.detail-page {
  padding: 24rpx;
  padding-bottom: 280rpx;
}

/* ─── Cards ─── */
.card {
  background: #ffffff;
  border: none;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f1f3;
}

.customer-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.customer-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1d21;
}

.platform-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.tag-dy { background: #1a1d21; color: #ffffff; }
.tag-xhs { background: #ff2442; color: #ffffff; }

.status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.status-assigned { background: #fef3c7; color: #92400e; }
.status-first_reply { background: #d1fae5; color: #065f46; }
.status-wechat_invited { background: #dbeafe; color: #1e40af; }
.status-completed { background: #f0f1f3; color: #6b7280; }

/* ─── Info Grid ─── */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.info-cell {
  padding: 8rpx 0;
}

.info-label {
  display: block;
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 6rpx;
  font-weight: 500;
}

.info-value {
  display: block;
  font-size: 28rpx;
  color: #1a1d21;
}

/* ─── Contact Bar ─── */
.contact-bar {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f1f3;
}

.contact-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx;
  background: #f8f9fb;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #3b82f6;
  font-weight: 500;
}

/* ─── Summary ─── */
.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1d21;
  margin-bottom: 16rpx;
}

.summary-text {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.8;
  background: #f8f9fb;
  border: none;
  padding: 20rpx;
  border-radius: 12rpx;
}

/* ─── Timeline ─── */
.timeline {
  padding-left: 16rpx;
}

.tl-item {
  display: flex;
  gap: 20rpx;
  padding-bottom: 28rpx;
  position: relative;
}

.tl-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 32rpx;
  bottom: 0;
  width: 2rpx;
  background: #e8eaed;
}

.tl-done::after {
  background: #10b981 !important;
}

.tl-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.tl-done .tl-dot {
  background: #10b981;
}

@keyframes dot-pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.4); opacity: 0.7; }
}

.tl-pending .tl-dot {
  background: #e8eaed;
}

.tl-active .tl-dot {
  background: #f59e0b;
  animation: dot-pulse 2s ease-in-out infinite;
}

.tl-content {
  flex: 1;
}

.tl-label {
  display: block;
  font-size: 26rpx;
  color: #1a1d21;
  font-weight: 500;
}

.tl-time {
  display: block;
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 6rpx;
}

.tl-sla {
  display: block;
  font-size: 22rpx;
  margin-top: 4rpx;
  font-weight: 500;
}

.tl-waiting {
  display: block;
  font-size: 22rpx;
  color: #f59e0b;
  margin-top: 4rpx;
}

.tl-status-text {
  display: block;
  font-size: 24rpx;
  color: #3b82f6;
  margin-top: 6rpx;
  font-weight: 500;
}

/* ─── Action Area ─── */
.action-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
}

.action-btn-big {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.btn-icon {
  font-size: 36rpx;
  margin-bottom: 10rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.btn-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 6rpx;
}

.btn-primary {
  background: #1a1d21;
}

.btn-success {
  background: #059669;
}

.btn-warning {
  background: #d97706;
}

.completed-box {
  text-align: center;
  padding: 48rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.completed-icon {
  display: block;
  font-size: 52rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.completed-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* ─── Bottom Sheet ─── */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
}

.bottom-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #ffffff;
  border: none;
  border-radius: 28rpx 28rpx 0 0;
  padding: 28rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  z-index: 101;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.sheet-title {
  display: block;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1d21;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f1f3;
  margin-bottom: 12rpx;
}

.sheet-option {
  padding: 28rpx 16rpx;
  text-align: center;
  font-size: 30rpx;
  color: #1a1d21;
  border-bottom: 1rpx solid #f0f1f3;
  border-radius: 12rpx;
}

.sheet-option:active {
  background: #f8f9fb;
}

.sheet-cancel {
  padding: 28rpx 16rpx;
  text-align: center;
  font-size: 28rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

/* ─── Tags ─── */
.tag-edit-btn {
  font-size: 24rpx;
  color: #3b82f6;
  font-weight: 500;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tag-chip {
  display: flex;
  align-items: center;
  background: #f0f5ff;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
}

.tag-chip-text {
  font-size: 24rpx;
  color: #1e40af;
}

.tag-chip-del {
  font-size: 22rpx;
  color: #9ca3af;
  margin-left: 8rpx;
  padding: 0 4rpx;
}

.tags-empty {
  font-size: 24rpx;
  color: #c4cad4;
}

.tag-edit-area {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f1f3;
}

.preset-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.preset-chip {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: #f8f9fb;
  color: #6b7280;
}

.preset-active {
  background: #1a1d21;
  color: #ffffff;
}

.tag-input-row {
  display: flex;
  gap: 12rpx;
}

.tag-input {
  flex: 1;
  height: 68rpx;
  background: #f8f9fb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.tag-add-btn {
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 28rpx;
  background: #1a1d21;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* ─── Loading ─── */
.loading-page {
  text-align: center;
  padding: 200rpx 0;
  color: #c4cad4;
}
