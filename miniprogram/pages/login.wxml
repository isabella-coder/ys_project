<view class="login-page">
  <view class="login-card">
    <view class="brand-header">
      <view class="brand-logo">B</view>
      <text class="brand-name">BOP 保镖</text>
    </view>
    <view class="title-wrap">
      <text class="title">经营账号登录</text>
      <text class="subtitle">支持店长 / 销售 / 财务 / 施工</text>
    </view>

    <view class="form-item">
      <text class="label">账号</text>
      <picker mode="selector" range="{{accountOptions}}" range-key="display_name" value="{{selectedIndex}}" bindchange="onAccountChange">
        <view class="picker-box">
          <text class="{{selectedAccountId ? '' : 'placeholder'}}">{{selectedLabel || '请选择账号'}}</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">密码</text>
      <input
        class="input"
        type="password"
        placeholder="请输入登录密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <view class="remember-row">
      <checkbox-group bindchange="onRememberChange">
        <label class="remember-label">
          <checkbox value="remember" checked="{{rememberAccount}}" />
          <text>记住账号</text>
        </label>
      </checkbox-group>
    </view>

    <button class="login-btn" bindtap="handleLogin" loading="{{loading}}" disabled="{{loading}}">
      登录
    </button>
  </view>
</view>
