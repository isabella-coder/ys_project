.login-page {
  min-height: 100vh;
  background: #f8f9fb;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.login-card {
  background: #ffffff;
  border: none;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  padding: 48rpx 36rpx;
}

.brand-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.brand-logo {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #1a1d21, #374151);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: -1rpx;
}

.brand-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1d21;
  letter-spacing: 1rpx;
}

.title-wrap {
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1d21;
  letter-spacing: 1rpx;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
  letter-spacing: 0.5rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #6b7280;
}

.input,
.picker-box {
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #fafbfc;
  padding: 24rpx;
  font-size: 30rpx;
  color: #1a1d21;
  transition: border-color 0.2s;
}

.placeholder {
  color: #c4cad4;
}

.remember-row {
  margin-bottom: 36rpx;
}

.remember-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.login-btn {
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 16rpx;
  background: #1a1d21;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: none;
}
