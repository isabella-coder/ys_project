.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef7ff 0%, #f7fbff 100%);
  padding: 56rpx 28rpx;
  box-sizing: border-box;
}

.login-card {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(35, 90, 170, 0.12);
  padding: 36rpx 28rpx;
}

.title-wrap {
  margin-bottom: 32rpx;
}

.title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #1f2d3d;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7a8ea6;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #4b5f77;
}

.input,
.picker-box {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #d6e3f3;
  border-radius: 12rpx;
  background: #fbfdff;
  padding: 20rpx;
  font-size: 28rpx;
  color: #263849;
}

.placeholder {
  color: #9baec2;
}

.remember-row {
  margin-bottom: 24rpx;
}

.remember-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #5f7187;
}

.login-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 12rpx;
  background: #2f84ff;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}
