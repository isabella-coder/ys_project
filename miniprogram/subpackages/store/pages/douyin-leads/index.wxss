.leads-page { padding-bottom: 40rpx; }

.followup-alert {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border-radius: 12rpx;
  border-left: 6rpx solid #f59e0b;
}
.alert-icon { font-size: 32rpx; margin-right: 12rpx; }
.alert-text { flex: 1; font-size: 26rpx; color: #92400e; font-weight: 600; }
.alert-arrow { font-size: 36rpx; color: #b45309; }

.stats-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.stat-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}
.stat-num { display: block; font-size: 40rpx; font-weight: 700; }
.stat-label { display: block; font-size: 22rpx; color: #6b7280; margin-top: 4rpx; }
.stat-s .stat-num { color: #dc2626; }
.stat-a .stat-num { color: #f59e0b; }
.stat-b .stat-num { color: #3b82f6; }
.stat-c .stat-num { color: #9ca3af; }

.search-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.search-input {
  flex: 1;
  height: 68rpx;
  background: #fff;
  border-radius: 34rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
  border: 1rpx solid #e5e7eb;
}
.search-btn {
  width: 120rpx;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  background: #0f172a;
  color: #fff;
  border-radius: 34rpx;
  font-size: 26rpx;
}

.tab-bar {
  display: flex;
  white-space: nowrap;
  margin-bottom: 12rpx;
  padding: 0 4rpx;
}
.status-tab-bar { margin-bottom: 20rpx; }
.tab-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #6b7280;
  border-radius: 30rpx;
  margin-right: 12rpx;
  background: #fff;
}
.tab-status { font-size: 24rpx; padding: 8rpx 22rpx; }
.tab-active {
  background: #0f172a;
  color: #fff;
  font-weight: 600;
}

.loading-box, .empty-box {
  text-align: center;
  padding: 80rpx 0;
  color: #9ca3af;
}
.empty-icon { display: block; font-size: 64rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; }

.lead-card { margin-bottom: 20rpx; }

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.card-left { display: flex; align-items: center; gap: 12rpx; flex: 1; }
.card-right { display: flex; align-items: center; gap: 12rpx; }
.customer-name { font-size: 32rpx; font-weight: 600; }

.grade-tag {
  display: inline-block;
  padding: 2rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}
.grade-S { background: linear-gradient(135deg, #dc2626, #b91c1c); }
.grade-A { background: linear-gradient(135deg, #f59e0b, #d97706); }
.grade-B { background: linear-gradient(135deg, #3b82f6, #2563eb); }
.grade-C { background: #9ca3af; }

.source-tag {
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  background: #111827;
  color: #fff;
}

.score-text { font-size: 24rpx; color: #6b7280; }

.lead-status {
  display: inline-block;
  padding: 2rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.status-pending { background: #fef3c7; color: #92400e; }
.status-contacted { background: #dbeafe; color: #1e40af; }
.status-visited { background: #d1fae5; color: #065f46; }
.status-closed { background: #dcfce7; color: #14532d; }
.status-lost { background: #f3f4f6; color: #6b7280; }

.card-body { margin-bottom: 12rpx; }
.info-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 8rpx;
}
.info-item { font-size: 26rpx; color: #374151; }

.grade-reasons {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}
.reason-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.followup-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  padding: 10rpx 16rpx;
  background: #f8fafc;
  border-radius: 10rpx;
}
.followup-label { font-size: 24rpx; color: #6b7280; }
.followup-dots { display: flex; gap: 8rpx; }
.followup-dot {
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
}
.fu-done { background: #dcfce7; color: #14532d; }
.fu-pending { background: #f1f5f9; color: #9ca3af; }

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid #f1f5f9;
}
.sales-text { font-size: 24rpx; color: #374151; }
.time-text { font-size: 22rpx; color: #9ca3af; }

.action-bar {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f1f5f9;
}
.action-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
}
.action-call { background: #eff6ff; color: #1d4ed8; }
.action-wechat { background: #f0fdf4; color: #15803d; }
.action-status { background: #fefce8; color: #a16207; }
.action-convert { background: #0f172a; color: #fff; }

.summary-preview {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #f8fafc;
  border-radius: 12rpx;
}
.summary-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 8rpx;
}
.summary-text {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}
.summary-expanded {
  -webkit-line-clamp: unset;
}

.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 0;
}
.page-btn {
  padding: 12rpx 32rpx;
  background: #0f172a;
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
}
.page-disabled {
  background: #e5e7eb;
  color: #9ca3af;
}
.page-info { font-size: 26rpx; color: #6b7280; }
