.page {
  min-height: 100vh;
  padding: 20rpx;
  background: #f8f9fb;
  box-sizing: border-box;
}

.summary-card {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
  background: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.summary-item {
  text-align: center;
}

.summary-label {
  font-size: 22rpx;
  color: #9ca3af;
  display: block;
}

.summary-value {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1d21;
}

.summary-value.warning {
  color: #b7791f;
}

.summary-value.success {
  color: #059669;
}

.view-tabs,
.status-tabs {
  display: flex;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.view-tab,
.status-tab {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #6b7280;
  background: #f0f1f3;
  border-radius: 12rpx;
  padding: 10rpx 0;
}

.view-tab.active,
.status-tab.active {
  background: #1a1d21;
  color: #fff;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 12rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-input {
  flex: 1;
  min-height: 64rpx;
  border: 2rpx solid #e8eaed;
  border-radius: 12rpx;
  padding: 0 16rpx;
}

.search-clear {
  color: #1a1d21;
  font-size: 24rpx;
}

.batch-bar {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.batch-toggle-btn {
  margin: 0;
  align-self: flex-start;
  border: none;
  border-radius: 12rpx;
  background: #1a1d21;
  color: #fff;
  line-height: 1.8;
  padding: 0 24rpx;
}

.batch-actions {
  background: #fff;
  border-radius: 12rpx;
  padding: 10rpx 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.batch-count {
  font-size: 24rpx;
  color: #3d4148;
}

.batch-link {
  font-size: 24rpx;
  color: #1a1d21;
}

.batch-submit-btn {
  margin: 0 0 0 auto;
  border: none;
  border-radius: 12rpx;
  background: #1a1d21;
  color: #fff;
  line-height: 1.8;
  padding: 0 20rpx;
}

.batch-result {
  background: #fff;
  border-radius: 12rpx;
  padding: 12rpx;
  margin-bottom: 14rpx;
}

.batch-result-head {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.batch-result-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1d21;
}

.batch-result-summary {
  font-size: 22rpx;
  color: #6b7280;
}

.batch-result-filters {
  margin-top: 10rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.batch-filter-chip {
  font-size: 22rpx;
  color: #3d4148;
  background: #f0f1f3;
  border-radius: 12rpx;
  padding: 4rpx 14rpx;
}

.batch-filter-chip.active {
  background: #1a1d21;
  color: #fff;
}

.batch-reason-row {
  margin-top: 10rpx;
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.batch-reason-tag {
  font-size: 20rpx;
  color: #6b7280;
  background: #f0f1f3;
  border-radius: 12rpx;
  padding: 4rpx 12rpx;
}

.batch-result-list {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.batch-result-item {
  border-radius: 12rpx;
  padding: 10rpx 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.batch-result-item.is-fail {
  background: #fef2f2;
}

.batch-result-item.is-skip {
  background: #f0f1f3;
}

.batch-result-id {
  font-size: 20rpx;
  color: #1e293b;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 12rpx;
  padding: 2rpx 10rpx;
}

.batch-result-msg {
  flex: 1;
  font-size: 22rpx;
  color: #3d4148;
}

.batch-result-empty {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.batch-result-actions {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.batch-result-refresh {
  margin: 0;
  border-radius: 12rpx;
  background: #f0f1f3;
  color: #1e293b;
  line-height: 1.8;
  padding: 0 20rpx;
}

.batch-result-retry {
  margin: 0;
  border: none;
  border-radius: 12rpx;
  background: #059669;
  color: #fff;
  line-height: 1.8;
  padding: 0 20rpx;
}

.batch-result-close {
  margin: 0;
  border: none;
  border-radius: 12rpx;
  background: #1a1d21;
  color: #fff;
  line-height: 1.8;
  padding: 0 20rpx;
}

.state-box {
  background: #fff;
  border-radius: 12rpx;
  padding: 40rpx 20rpx;
  text-align: center;
  color: #9ca3af;
}

.error-box {
  color: #dc2626;
}

.retry-btn {
  margin-top: 12rpx;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.order-card {
  background: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.order-card-selected {
  box-shadow: 0 0 0 2rpx #1a1d21 inset;
}

.order-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-id-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.select-dot {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  border: 1rpx solid #94a3b8;
  background: #fff;
}

.select-dot.selected {
  border-color: #1a1d21;
  background: #1a1d21;
}

.order-id {
  font-size: 24rpx;
  color: #9ca3af;
}

.status-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.status-pending {
  background: #fef3c7;
  color: #92400e;
}

.status-done {
  background: #d1fae5;
  color: #065f46;
}

.status-cancel {
  background: #fef2f2;
  color: #dc2626;
}

.line {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #3d4148;
}

.order-actions {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
}

.quick-btn {
  margin: 0;
  border: none;
  border-radius: 12rpx;
  background: #1a1d21;
  color: #fff;
  line-height: 1.8;
  padding: 0 20rpx;
  font-size: 20rpx;
}

.commission-line {
  color: #059669;
  font-weight: 600;
}
.order-foot {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.service-tag {
  font-size: 20rpx;
  color: #1a1d21;
  background: #f0f1f3;
  border-radius: 12rpx;
  padding: 4rpx 12rpx;
}

.price {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1d21;
}
