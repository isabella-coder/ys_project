.top-card {
  background: #ffffff;
  color: #1a1d21;
  border-left: none;
}

.top-card .hint {
  color: #6b7280;
  margin-bottom: 12rpx;
}

.form-item {
  margin-top: 12rpx;
}

.stats-card {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.stat-item {
  border: none;
  border-radius: 14rpx;
  padding: 14rpx;
  background: #f8f9fb;
}

.stat-label {
  color: #9ca3af;
  font-size: 24rpx;
}

.stat-value {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1d21;
}

.stat-value.primary {
  color: #1d4ed8;
}

.stat-value.warning {
  color: #92400e;
}

.stat-value.success {
  color: #059669;
}

.stat-value.danger {
  color: #dc2626;
}

.slot-card {
  border: none;
}

.slot-card-conflict {
  border-color: #fca5a5;
  background: #fff1f2;
}

.slot-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.slot-time {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1d21;
}

.slot-status {
  color: #3d4148;
}

.slot-empty {
  color: #9ca3af;
}

.order-item {
  border: none;
  border-radius: 20rpx;
  padding: 14rpx;
  margin-bottom: 12rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.order-item:last-child {
  margin-bottom: 0;
}

.order-line {
  color: #1a1d21;
  margin-bottom: 8rpx;
}

.status-row {
  margin-bottom: 10rpx;
}

.status-tag {
  display: inline-block;
  border-radius: 12rpx;
  padding: 4rpx 14rpx;
  font-size: 22rpx;
}

.status-pending {
  background: #fef3c7;
  color: #92400e;
}

.status-assigned {
  background: #dbeafe;
  color: #1d4ed8;
}

.status-completed {
  background: #d1fae5;
  color: #059669;
}

.status-cancelled {
  background: #fef2f2;
  color: #dc2626;
}

.button-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin-top: 10rpx;
}

.mini-btn {
  margin: 0;
  line-height: 1.8;
  border: none;
  border-radius: 12rpx;
  background: #1a1d21;
  color: #ffffff;
  padding: 0 18rpx;
}

@media (max-width: 420px) {
  .stats-card {
    grid-template-columns: 1fr;
  }

  .slot-head {
    flex-direction: column;
    align-items: flex-start;
    gap: 8rpx;
  }

  .button-row {
    grid-template-columns: 1fr;
  }
}
