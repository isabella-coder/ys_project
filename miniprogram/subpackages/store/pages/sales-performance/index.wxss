.top-card {
  background: #ffffff;
  color: #1a1d21;
  border-left: none;
}

.top-card .hint {
  color: #6b7280;
  margin-bottom: 12rpx;
}

.date-filter {
  margin-bottom: 12rpx;
}

.date-label {
  display: block;
  margin-bottom: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.date-picker {
  min-height: 72rpx;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
  color: #1a1d21;
  background: #ffffff;
}

.tabs {
  display: flex;
  gap: 10rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 10rpx;
  border-radius: 12rpx;
  color: #6b7280;
  background: #f0f1f3;
}

.tab-item.active {
  background: #1a1d21;
  color: #ffffff;
  font-weight: 600;
}

.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.summary-item {
  border: none;
  border-radius: 12rpx;
  padding: 14rpx;
  background: #f8f9fb;
}

.summary-label {
  color: #9ca3af;
  font-size: 24rpx;
}

.summary-value {
  display: block;
  margin-top: 8rpx;
  color: #1a1d21;
  font-size: 30rpx;
  font-weight: 700;
}

.period-row {
  border: none;
  border-radius: 12rpx;
  padding: 14rpx;
  margin-bottom: 10rpx;
  background: #f8f9fb;
}

.period-row:last-child {
  margin-bottom: 0;
}

.period-row-active {
  border-color: #1d4ed8;
  background: #eff6ff;
}

.period-line {
  color: #1a1d21;
  margin-bottom: 6rpx;
}

.period-line:last-child {
  margin-bottom: 0;
  color: #3d4148;
}

.sales-row {
  border-bottom: 1rpx solid #f0f1f3;
  padding: 10rpx 0;
}

.sales-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.sales-line {
  color: #1a1d21;
  margin-bottom: 4rpx;
}

.sales-name {
  font-weight: 600;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1d21;
}

.empty-subtitle {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
}
