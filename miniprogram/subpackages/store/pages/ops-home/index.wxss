.ops-page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f8f9fb;
  box-sizing: border-box;
}

.hero {
  background: #ffffff;
  border: none;
  border-radius: 20rpx;
  color: #1a1d21;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.hero-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  letter-spacing: 0.5rpx;
}

.hero-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.logout-btn {
  margin: 0;
  min-width: 150rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 12rpx;
  border: none;
  color: #6b7280;
  background: #f0f1f3;
  font-size: 24rpx;
  font-weight: 500;
}

.hero-role {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
}

.overview-box {
  margin-bottom: 16rpx;
  background: #ffffff;
  border: none;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.overview-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.overview-title {
  font-size: 30rpx;
  color: #1a1d21;
  font-weight: 600;
}

.overview-date {
  color: #9ca3af;
  font-size: 22rpx;
}

.overview-loading {
  font-size: 24rpx;
  color: #9ca3af;
}

.metrics-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.metric-card {
  min-height: 104rpx;
  border: none;
  border-radius: 14rpx;
  padding: 14rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: #f8f9fb;
}

.metric-label {
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 6rpx;
  font-weight: 500;
}

.metric-value {
  font-size: 32rpx;
  color: #1a1d21;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}

.chain-card {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 20rpx;
  border: none;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.chain-film {
  border-left: none;
}

.chain-wash {
  border-left: none;
}

.chain-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chain-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1d21;
}

.chain-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #9ca3af;
  font-size: 24rpx;
  line-height: 1.5;
}

.chain-btn {
  margin: 16rpx 0 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 12rpx;
  background: #1a1d21;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
  padding: 0 24rpx;
  border: none;
}

.quick-box {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 20rpx;
  border: none;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.quick-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1d21;
  margin-bottom: 16rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.quick-item {
  min-height: 80rpx;
  border-radius: 14rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  box-sizing: border-box;
  background: #f8f9fb;
}

.quick-name {
  font-size: 24rpx;
  text-align: center;
  color: #1a1d21;
  font-weight: 500;
}
