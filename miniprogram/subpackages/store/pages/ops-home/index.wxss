.ops-page {
  min-height: 100vh;
  padding: 24rpx 22rpx 40rpx;
  background: #eceff3;
  box-sizing: border-box;
}

.hero {
  background: linear-gradient(135deg, #1f2a44, #2f4f80);
  border-radius: 16rpx;
  color: #fff;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  opacity: 0.92;
}

.hero-role {
  display: inline-block;
  margin-top: 14rpx;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  border-radius: 999rpx;
}

.chain-card {
  margin-top: 18rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 2rpx solid #d3d9e3;
  padding: 24rpx 24rpx 22rpx;
  box-shadow: 0 3rpx 10rpx rgba(17, 24, 39, 0.05);
}

.chain-film {
  border-left: 10rpx solid #111827;
}

.chain-wash {
  border-left: 10rpx solid #6b7280;
}

.chain-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chain-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #111827;
}

.chain-tag {
  font-size: 28rpx;
  color: #6b7280;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  border: 2rpx solid #d7dce3;
  background: #f8fafc;
}

.chain-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.5;
}

.chain-btn {
  margin: 20rpx 0 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 0 26rpx;
  border: none;
}

.quick-box {
  margin-top: 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 2rpx solid #e0e5ec;
  padding: 22rpx 20rpx;
}

.quick-title {
  display: block;
  font-size: 52rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.quick-item {
  height: 96rpx;
  border-radius: 14rpx;
  border: 2rpx solid #d7dce3;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.quick-name {
  font-size: 40rpx;
  color: #1f2937;
  font-weight: 600;
}
