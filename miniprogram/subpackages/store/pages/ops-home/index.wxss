.ops-page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f5f7fb;
  box-sizing: border-box;
}

.hero {
  background: linear-gradient(135deg, #1f2a44, #2f4f80);
  border-radius: 16rpx;
  color: #fff;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  opacity: 0.92;
}

.hero-role {
  display: inline-block;
  margin-top: 14rpx;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  border-radius: 999rpx;
}

.module-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.module-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(31, 42, 68, 0.08);
}

.module-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.module-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #24324a;
}

.module-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #eef3ff;
  color: #2f4f80;
}

.module-desc {
  font-size: 24rpx;
  color: #6e7a91;
}

.hint-box {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  border-left: 8rpx solid #2f4f80;
}

.hint-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #24324a;
  margin-bottom: 8rpx;
}

.hint-text {
  display: block;
  font-size: 24rpx;
  color: #5f6b83;
  line-height: 1.7;
}
