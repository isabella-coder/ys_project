<view class="ops-page">
  <view class="hero">
    <text class="hero-title">经营中心</text>
    <text class="hero-subtitle">覆盖贴膜与洗车双链路：下单、派工、绩效、回访。</text>
    <text class="hero-role">当前角色：{{roleLabel}}</text>
  </view>

  <view class="chain-card chain-film">
    <view class="chain-head">
      <text class="chain-title">贴膜链路</text>
      <text class="chain-tag">FILM</text>
    </view>
    <text class="chain-subtitle">贴膜下单、派工、提成、回访、销售业绩</text>
    <button class="chain-btn" bindtap="onOpenRoute" data-route="{{filmChain.route}}">进入贴膜链路  &gt;</button>
  </view>

  <view class="chain-card chain-wash">
    <view class="chain-head">
      <text class="chain-title">洗车链路</text>
      <text class="chain-tag">WASH</text>
    </view>
    <text class="chain-subtitle">整点预约、洗车派工、施工图片、固定提成</text>
    <button class="chain-btn" bindtap="onOpenRoute" data-route="{{washChain.route}}">进入洗车链路  &gt;</button>
  </view>

  <view class="quick-box">
    <text class="quick-title">常用入口</text>
    <view class="quick-grid">
      <view class="quick-item" wx:for="{{quickEntries}}" wx:key="key" bindtap="onOpenRoute" data-route="{{item.route}}">
        <text class="quick-name">{{item.name}}</text>
      </view>
    </view>
  </view>
</view>
