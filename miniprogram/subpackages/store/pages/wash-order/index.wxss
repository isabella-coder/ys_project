@import "../film-order/index.wxss";

.chain-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.chain-item {
  border-radius: 12rpx;
  padding: 18rpx;
  text-align: center;
  border: none;
}

.chain-item-muted {
  background: #f8f9fb;
  color: #3d4148;
}

.chain-item-active {
  background: #1a1d21;
  color: #ffffff;
  border-color: #1a1d21;
  font-weight: 600;
}

.line {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.line.total {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx dashed #d1d5db;
  font-size: 32rpx;
  font-weight: 600;
}
