.top-card {
  background: #ffffff;
  color: #1a1d21;
  border-left: none;
}

.top-card .hint {
  color: #6b7280;
  margin-bottom: 16rpx;
}

.form-item {
  margin-top: 12rpx;
}

.stats-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.stat-item {
  border: none;
  border-radius: 14rpx;
  padding: 14rpx;
  background: #f8f9fb;
}

.stat-label {
  color: #9ca3af;
  font-size: 24rpx;
}

.stat-value {
  display: block;
  margin-top: 8rpx;
  color: #1a1d21;
  font-size: 34rpx;
  font-weight: 700;
}

.stat-value.success {
  color: #059669;
}

.stat-value.warning {
  color: #92400e;
}

.stat-value.danger {
  color: #dc2626;
}

.empty-card {
  text-align: center;
  padding-top: 56rpx;
  padding-bottom: 56rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1d21;
}

.empty-subtitle {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.conflict-card {
  border: 1rpx solid #fecaca;
  background: #fff1f2;
}

.conflict-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.conflict-item:last-child {
  margin-bottom: 0;
}

.conflict-text {
  color: #7f1d1d;
  flex: 1;
}

.group-block {
  margin-bottom: 16rpx;
}

.group-block:last-child {
  margin-bottom: 0;
}

.group-title {
  margin-bottom: 10rpx;
  color: #1a1d21;
  font-weight: 600;
}

.entry-item {
  border: none;
  border-radius: 12rpx;
  padding: 14rpx;
  margin-bottom: 10rpx;
  background: #f8f9fb;
}

.entry-item:last-child {
  margin-bottom: 0;
}

.entry-item-conflict {
  border-color: #fca5a5;
  background: #fff1f2;
}

.entry-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.entry-tag {
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
  background: #f0f1f3;
  color: #1e293b;
  font-size: 20rpx;
}

.entry-line {
  margin-top: 8rpx;
  color: #3d4148;
  font-size: 24rpx;
}

.mini-btn {
  margin-top: 10rpx;
  margin-left: 0;
  line-height: 1.8;
  border: none;
  border-radius: 12rpx;
  background: #1a1d21;
  color: #ffffff;
  padding: 0 18rpx;
}

@media (max-width: 420px) {
  .stats-card {
    grid-template-columns: 1fr;
  }

  .entry-head {
    flex-direction: column;
    align-items: flex-start;
  }

  .mini-btn {
    width: 100%;
  }
}
