.top-card {
  background: linear-gradient(140deg, #0f172a, #1e293b);
  color: #f8fafc;
}

.top-card .hint {
  color: #cbd5e1;
}

.stats-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.stat-item {
  border: 2rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 14rpx;
  background: #f8fafc;
}

.stat-label {
  color: #64748b;
  font-size: 24rpx;
}

.stat-value {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.stat-value.due {
  color: #92400e;
}

.stat-value.overdue {
  color: #b91c1c;
}

.stat-value.done {
  color: #166534;
}

.tabs {
  display: flex;
  gap: 10rpx;
  padding: 12rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 10rpx 8rpx;
  border-radius: 10rpx;
  background: #f1f5f9;
  color: #334155;
  font-size: 24rpx;
}

.tab-item.active {
  background: #0f172a;
  color: #ffffff;
}

.empty-card {
  text-align: center;
  padding-top: 56rpx;
  padding-bottom: 56rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
}

.empty-subtitle {
  margin-top: 10rpx;
  color: #64748b;
}

.reminder-card {
  margin-bottom: 20rpx;
}

.reminder-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.reminder-id {
  color: #334155;
  font-size: 26rpx;
}

.status-pill {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-pill.status-pending {
  background: #e2e8f0;
  color: #1e293b;
}

.status-pill.status-due {
  background: #fef3c7;
  color: #92400e;
}

.status-pill.status-overdue {
  background: #fee2e2;
  color: #991b1b;
}

.status-pill.status-done {
  background: #dcfce7;
  color: #166534;
}

.reminder-line {
  margin-top: 8rpx;
  color: #1f2937;
}

.action-row {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
}

.mini-btn {
  margin: 0;
  line-height: 1.8;
  border-radius: 999rpx;
  padding: 0 18rpx;
}

.mini-btn.primary {
  border: none;
  background: #0f172a;
  color: #ffffff;
}

.mini-btn.secondary {
  border: 2rpx solid #d1d5db;
  background: #ffffff;
  color: #1f2937;
}
