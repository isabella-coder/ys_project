.top-card {
  background: #ffffff;
  color: #1a1d21;
  border-left: none;
}

.top-card .hint {
  color: #6b7280;
}

.stats-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.stat-item {
  border: none;
  border-radius: 14rpx;
  padding: 14rpx;
  background: #f8f9fb;
}

.stat-label {
  color: #9ca3af;
  font-size: 24rpx;
}

.stat-value {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1d21;
}

.stat-value.due {
  color: #92400e;
}

.stat-value.overdue {
  color: #b91c1c;
}

.stat-value.done {
  color: #059669;
}

.tabs {
  display: flex;
  gap: 10rpx;
  padding: 12rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 10rpx 8rpx;
  border-radius: 12rpx;
  background: #f0f1f3;
  color: #3d4148;
  font-size: 24rpx;
}

.tab-item.active {
  background: #1a1d21;
  color: #ffffff;
}

.empty-card {
  text-align: center;
  padding-top: 56rpx;
  padding-bottom: 56rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1d21;
}

.empty-subtitle {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.reminder-card {
  margin-bottom: 20rpx;
}

.reminder-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.reminder-id {
  color: #3d4148;
  font-size: 28rpx;
}

.status-pill {
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.status-pill.status-pending {
  background: #f0f1f3;
  color: #1e293b;
}

.status-pill.status-due {
  background: #fef3c7;
  color: #92400e;
}

.status-pill.status-overdue {
  background: #fef2f2;
  color: #dc2626;
}

.status-pill.status-done {
  background: #d1fae5;
  color: #059669;
}

.reminder-line {
  margin-top: 8rpx;
  color: #1a1d21;
}

.action-row {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
}

.mini-btn {
  margin: 0;
  line-height: 1.8;
  border-radius: 12rpx;
  padding: 0 18rpx;
}

.mini-btn.primary {
  border: none;
  background: #1a1d21;
  color: #ffffff;
}

.mini-btn.secondary {
  border: none;
  background: #ffffff;
  color: #1a1d21;
}

@media (max-width: 420px) {
  .stats-card {
    grid-template-columns: 1fr;
  }

  .tabs {
    flex-wrap: wrap;
  }

  .tab-item {
    flex: none;
    width: calc(50% - 5rpx);
  }

  .action-row {
    flex-direction: column;
  }

  .mini-btn {
    width: 100%;
  }
}
