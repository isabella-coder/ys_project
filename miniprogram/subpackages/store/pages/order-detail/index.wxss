.page {
  min-height: 100vh;
  padding: 20rpx;
  background: #f8f9fb;
  box-sizing: border-box;
}

.state-box {
  background: #fff;
  border-radius: 12rpx;
  padding: 40rpx 20rpx;
  text-align: center;
  color: #9ca3af;
}

.error-box {
  color: #dc2626;
}

.retry-btn {
  margin-top: 12rpx;
}

.container {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.card {
  background: #ffffff;
  border: none;
  border-radius: 20rpx;
  padding: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.top-card {
  background: #ffffff;
  color: #1a1d21;
  border-left: none;
}

.small-label {
  color: #6b7280;
  font-size: 24rpx;
}

.order-id {
  margin-top: 6rpx;
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.status-row {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.time-text {
  color: #6b7280;
  font-size: 22rpx;
}

.role-hint {
  margin-top: 12rpx;
  color: #6b7280;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1d21;
  margin-bottom: 12rpx;
}

.status-badge {
  border-radius: 12rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
}

.status-pending {
  background: #fef3c7;
  color: #92400e;
}

.status-confirmed {
  background: #d1fae5;
  color: #059669;
}

.status-cancelled {
  background: #fef2f2;
  color: #dc2626;
}

.line {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
  color: #1a1d21;
  gap: 24rpx;
  font-size: 24rpx;
}

.line text:last-child {
  text-align: right;
  word-break: break-all;
}

.hint {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.total {
  margin-top: 8rpx;
  padding-top: 10rpx;
  border-top: 1rpx dashed #d1d5db;
  font-weight: 700;
}

.form-item {
  margin-bottom: 18rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.picker,
.textarea {
  width: 100%;
  border: 2rpx solid #e8eaed;
  border-radius: 12rpx;
  padding: 12rpx 14rpx;
  box-sizing: border-box;
  font-size: 24rpx;
  color: #3d4148;
  background: #fff;
}

.textarea {
  min-height: 130rpx;
}

.multi-check-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 0;
}

.picker-readonly {
  background: #f0f1f3;
  color: #1a1d21;
}

.button-primary {
  margin-top: 8rpx;
  background: #1a1d21;
  color: #fff;
  border-radius: 12rpx;
}

.button-secondary {
  margin-top: 8rpx;
  background: #f0f1f3;
  color: #3d4148;
  border-radius: 12rpx;
}

.photo-section {
  margin-top: 18rpx;
}

.photo-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.upload-btn {
  margin: 0;
  background: #f0f1f3;
  color: #1a1d21;
  border: none;
  border-radius: 12rpx;
  padding: 0 18rpx;
}

.photo-empty {
  color: #6b7280;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.photo-card {
  position: relative;
}

.photo-image {
  width: 100%;
  height: 180rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
}

.photo-remove {
  position: absolute;
  right: 6rpx;
  top: 6rpx;
  background: rgba(17, 24, 39, 0.75);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
}

.part-record {
  margin-top: 14rpx;
  padding: 16rpx;
  border: none;
  border-radius: 12rpx;
  background: #f8f9fb;
}

.part-record-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.part-record-title {
  color: #1a1d21;
  font-weight: 600;
}

.part-record-time {
  color: #6b7280;
  font-size: 22rpx;
}

.part-record-line {
  margin-top: 8rpx;
  color: #3d4148;
  font-size: 24rpx;
}

.record-remove-btn {
  margin-top: 12rpx;
  margin-left: 0;
  background: #fef2f2;
  color: #dc2626;
  border: none;
  border-radius: 12rpx;
  line-height: 1.8;
  padding: 0 18rpx;
}

.commission-list {
  margin: 8rpx 0 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx dashed #d1d5db;
}

.commission-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  color: #1a1d21;
  margin-bottom: 8rpx;
}

.amount-negative {
  color: #dc2626;
}

/* 裁膜费 */
.cutting-fee-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #d1d5db;
}

.section-subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1d21;
  margin-bottom: 8rpx;
}

.cutting-fee-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.cutting-fee-tag {
  padding: 10rpx 28rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: #f1f5f9;
  color: #64748b;
  border: 2rpx solid transparent;
}

.cutting-fee-tag.active {
  background: #eff6ff;
  color: #2563eb;
  border-color: #2563eb;
  font-weight: 500;
}
