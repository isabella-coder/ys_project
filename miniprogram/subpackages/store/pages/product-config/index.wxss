.line-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.item-title {
  font-weight: 600;
  color: #1a1d21;
}

.form-item {
  margin-bottom: 16rpx;
  padding: 12rpx;
  border: none;
  border-radius: 12rpx;
  background: #f8f9fb;
}

.input {
  width: 100%;
  min-height: 68rpx;
  border: 2rpx solid #e8eaed;
  border-radius: 12rpx;
  padding: 12rpx 14rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #3d4148;
  background: #ffffff;
}

.delete-btn {
  margin: 0;
  background: #fef2f2;
  color: #dc2626;
  border: none;
  border-radius: 12rpx;
  padding: 0 20rpx;
}
