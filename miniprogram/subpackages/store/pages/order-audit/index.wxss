.page {
  min-height: 100vh;
  padding: 20rpx;
  background: #f3f6fb;
  box-sizing: border-box;
}

.filter-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 14rpx;
  margin-bottom: 14rpx;
}

.date-preset-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.preset-chip {
  font-size: 22rpx;
  color: #334155;
  background: #e2e8f0;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
}

.preset-chip.active {
  background: #1f2a44;
  color: #fff;
}

.date-range-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.date-box {
  min-width: 200rpx;
  font-size: 24rpx;
  color: #334155;
  border: 1rpx solid #d7dfed;
  border-radius: 10rpx;
  padding: 10rpx 14rpx;
  background: #fff;
}

.date-sep {
  font-size: 22rpx;
  color: #64748b;
}

.date-apply-btn {
  margin: 0;
  border: none;
  border-radius: 999rpx;
  background: #0f766e;
  color: #fff;
  line-height: 1.8;
  padding: 0 20rpx;
}

.result-tabs {
  display: flex;
  gap: 10rpx;
}

.result-tab {
  flex: 1;
  text-align: center;
  background: #e2e8f0;
  color: #334155;
  border-radius: 10rpx;
  font-size: 24rpx;
  padding: 10rpx 0;
}

.result-tab.active {
  background: #1f2a44;
  color: #fff;
}

.action-tabs {
  margin-top: 10rpx;
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.action-tab {
  font-size: 22rpx;
  color: #334155;
  background: #edf2f7;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
}

.action-tab.active {
  background: #0f766e;
  color: #fff;
}

.sales-row {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.sales-label {
  font-size: 22rpx;
  color: #64748b;
  white-space: nowrap;
}

.sales-picker {
  min-width: 340rpx;
  font-size: 22rpx;
  color: #334155;
  border: 1rpx solid #d7dfed;
  border-radius: 10rpx;
  padding: 8rpx 12rpx;
  background: #fff;
}

.search-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.export-row {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.reset-btn {
  margin: 0;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #1e293b;
  line-height: 1.8;
  padding: 0 20rpx;
}

.export-btn {
  margin: 0;
  border: none;
  border-radius: 999rpx;
  background: #0f766e;
  color: #fff;
  line-height: 1.8;
  padding: 0 20rpx;
}

.quick-export-row {
  margin-top: 8rpx;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.quick-export-btn {
  margin: 0;
  border: none;
  border-radius: 999rpx;
  line-height: 1.8;
  padding: 0 20rpx;
}

.quick-export-btn.failed {
  background: #fee2e2;
  color: #b83232;
}

.quick-export-btn.skipped {
  background: #f1f5f9;
  color: #475569;
}

.search-input {
  flex: 1;
  min-height: 64rpx;
  border: 1rpx solid #d7dfed;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
}

.search-btn {
  margin: 0;
  border: none;
  border-radius: 999rpx;
  background: #1f2a44;
  color: #fff;
  line-height: 1.8;
  padding: 0 20rpx;
}

.clear-link {
  font-size: 24rpx;
  color: #2f4f80;
}

.summary-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 14rpx;
  margin-bottom: 14rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 10rpx;
}

.summary-item {
  text-align: center;
  background: #f8fafc;
  border-radius: 10rpx;
  padding: 10rpx 8rpx;
}

.summary-label {
  display: block;
  font-size: 20rpx;
  color: #64748b;
}

.summary-value {
  display: block;
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.summary-value.success {
  color: #1f7a46;
}

.summary-value.failed {
  color: #b83232;
}

.summary-value.skipped {
  color: #475569;
}

.summary-reasons {
  margin-top: 10rpx;
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.summary-actions {
  margin-top: 8rpx;
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.reason-chip {
  font-size: 20rpx;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
}

.reason-version {
  color: #9f1239;
  background: #ffe4e6;
}

.reason-permission {
  color: #9a3412;
  background: #ffedd5;
}

.reason-network {
  color: #1d4ed8;
  background: #dbeafe;
}

.reason-default {
  color: #475569;
  background: #f1f5f9;
}

.action-chip {
  font-size: 20rpx;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
}

.action-quick {
  color: #1d4ed8;
  background: #dbeafe;
}

.action-batch {
  color: #0f766e;
  background: #ccfbf1;
}

.action-detail {
  color: #9a3412;
  background: #ffedd5;
}

.action-default {
  color: #475569;
  background: #f1f5f9;
}

.summary-loading {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #64748b;
}

.state-box {
  background: #fff;
  border-radius: 12rpx;
  padding: 40rpx 20rpx;
  text-align: center;
  color: #7a869c;
}

.error-box {
  color: #c53030;
}

.retry-btn {
  margin-top: 12rpx;
}

.audit-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.summary-row {
  font-size: 24rpx;
  color: #64748b;
}

.audit-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx;
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-id {
  font-size: 24rpx;
  color: #334155;
}

.result-tag {
  font-size: 20rpx;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
}

.tag-success {
  background: #d9f2e3;
  color: #1f7a46;
}

.tag-failed {
  background: #fee2e2;
  color: #b83232;
}

.tag-skipped {
  background: #f1f5f9;
  color: #475569;
}

.line {
  margin-top: 8rpx;
  display: flex;
  gap: 8rpx;
  font-size: 24rpx;
  color: #475569;
}

.error-line {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #b83232;
  background: #fff5f5;
  border-radius: 8rpx;
  padding: 8rpx 10rpx;
}

.footer-tip {
  text-align: center;
  color: #7a869c;
  font-size: 22rpx;
  padding: 8rpx 0 16rpx;
}
