.hero {
  background: #ffffff;
  border-left: none;
  color: #1a1d21;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: #9ca3af;
}

.chain-card {
  padding-bottom: 18rpx;
}

.chain-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
}

.chain-item {
  border-radius: 16rpx;
  border: 2rpx solid #e8eaed;
  padding: 20rpx;
}

.chain-item-active {
  background: #1a1d21;
  border-color: #1a1d21;
  color: #ffffff;
}

.chain-item-muted {
  background: #f8f9fb;
  color: #1a1d21;
}

.chain-title {
  font-size: 28rpx;
  font-weight: 600;
}

.chain-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: inherit;
  opacity: 0.7;
}

.form-item {
  margin-bottom: 20rpx;
  padding: 16rpx;
  border: none;
  border-radius: 14rpx;
  background: #f8f9fb;
}

.input,
.picker,
.textarea {
  width: 100%;
  border: 2rpx solid #e8eaed;
  border-radius: 12rpx;
  padding: 20rpx 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  min-height: 84rpx;
  line-height: 1.5;
  color: #1a1d21;
  background: #ffffff;
}

.input::placeholder,
.textarea::placeholder {
  color: #c0c4cc;
  font-size: 26rpx;
}

.picker {
  min-height: 76rpx;
  display: flex;
  align-items: center;
}

.textarea {
  min-height: 150rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.section-title-no-margin {
  margin-bottom: 0;
  white-space: nowrap;
  flex-shrink: 0;
}

.edit-btn {
  margin: 0;
  line-height: 1.8;
  border: none;
  color: #ffffff;
  background: #1a1d21;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.package-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.package-item {
  position: relative;
  border: 2rpx solid #e8eaed;
  border-radius: 20rpx;
  padding: 20rpx;
  background: #ffffff;
}

.package-item.active {
  border-color: #1a1d21;
  background: #1a1d21;
  box-shadow: none;
}

.package-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1d21;
}

.package-desc {
  margin-top: 8rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.package-price {
  margin-top: 10rpx;
  color: #1a1d21;
  font-weight: 700;
}

.package-item.active .package-name,
.package-item.active .package-price {
  color: #ffffff;
}

.package-item.active .package-desc {
  color: rgba(255, 255, 255, 0.6);
}

.package-selected-tag {
  position: absolute;
  right: 14rpx;
  top: 14rpx;
  z-index: 4;
  display: flex;
  align-items: center;
  gap: 6rpx;
  border-radius: 8rpx;
  background: #10b981;
  border: none;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1;
  padding: 8rpx 14rpx;
}

.package-selected-icon {
  font-size: 20rpx;
  line-height: 1;
}

.add-ons {
  margin-top: 8rpx;
}

.addon-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.addon-fee {
  margin-left: auto;
  color: #1a1d21;
  font-weight: 500;
}

.addon-fee-free {
  color: #059669;
  font-weight: 600;
}

.proof-section {
  margin-top: 8rpx;
}

.proof-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.upload-btn {
  margin: 0;
  background: #f0f1f3;
  color: #1a1d21;
  border: none;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-weight: 500;
}

.photo-empty {
  color: #9ca3af;
  font-size: 24rpx;
  margin-bottom: 10rpx;
  padding: 24rpx;
  border: 2rpx dashed #e8eaed;
  border-radius: 14rpx;
  background: #ffffff;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.photo-card {
  position: relative;
}

.photo-image {
  width: 100%;
  height: 180rpx;
  border-radius: 12rpx;
  background: #f0f1f3;
}

.photo-remove {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  background: rgba(26, 29, 33, 0.7);
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
}

.price-card {
  border: none;
}

.price-line,
.price-total {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.price-total {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 2rpx solid #f0f1f3;
  font-size: 32rpx;
  font-weight: 700;
}
