# 环境变量配置示例
# 复制此文件为 .env 并填充实际值

# 应用配置
DEBUG=True
HOST=0.0.0.0
PORT=8000

# JWT 密钥 (生产环境必须修改)
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# 小程序轻量登录
MINIPROGRAM_SALES_PASSWORD=sale123
MINIPROGRAM_TOKEN_EXPIRE_MINUTES=10080
MINIPROGRAM_LOGIN_MAX_RETRIES=5
MINIPROGRAM_LOGIN_WINDOW_MINUTES=15
MINIPROGRAM_LOGIN_BLOCK_MINUTES=10

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=lx_center
# 腾讯云/远程 PostgreSQL 推荐直接配置完整连接串（优先级高于上面 DB_*）
# 示例: DATABASE_URL=postgresql://user:password@<腾讯云DB内网IP>:5432/xls_db?sslmode=disable
DATABASE_URL=
# 可选：当未使用 DATABASE_URL 时，用于附加连接参数
DB_SSL_MODE=
DB_CONNECT_TIMEOUT=10

# 经营系统内部调用令牌（用于 /api/v1/store/internal/*）
WEILAN_API_TOKEN=

# 企业微信配置
WECOM_CORP_ID=your_corp_id
WECOM_SECRET=your_secret
WECOM_AGENT_ID=1000000
WECOM_TOKEN=your_token

# OpenClaw 配置
OPENCLAW_API_URL=http://localhost:9000
OPENCLAW_API_KEY=your_api_key

# SLA 时效规则 (单位: 分钟)
SLA_1M_MINUTES=1
SLA_3M_MINUTES=3
SLA_10M_MINUTES=10

# 日志
LOG_LEVEL=INFO
