page {
  background: #f5f7fb;
  color: #111827;
  font-size: 28rpx;
}

.container {
  padding: 28rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 22rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.label {
  color: #374151;
  margin-bottom: 10rpx;
  display: block;
}

.input,
.textarea,
.picker {
  width: 100%;
  min-height: 76rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 14rpx;
  padding: 18rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.row {
  display: flex;
  gap: 16rpx;
}

.row-item {
  flex: 1;
}

.button-primary {
  width: 100%;
  background: linear-gradient(135deg, #1f2937, #111827);
  color: #ffffff !important;
  border-radius: 16rpx;
  border: none;
  margin-top: 20rpx;
}

.button-primary[disabled] {
  background: #94a3b8 !important;
  color: #ffffff !important;
  opacity: 1;
}

.button-secondary {
  width: 100%;
  background: #ffffff;
  color: #111827;
  border: 2rpx solid #d1d5db;
  border-radius: 16rpx;
  margin-top: 14rpx;
}

.hint {
  color: #6b7280;
  font-size: 24rpx;
}
